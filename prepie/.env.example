# prepie runs on seeded mock data with NO env vars set.
# Fill these in only when you're ready to wire the real database (see lib/db).

# Supabase Postgres connection string (use the "Connection pooling" URI, port 6543).
# For the "Prepi" project (ref beznhteumkduzxpqyfci, region us-east-1) the pooler
# URI looks like this — paste your DB password where shown, then put the line in
# .env.local (gitignored):
#   postgresql://postgres.beznhteumkduzxpqyfci:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Later, for the P1 intelligence layer:
# ANTHROPIC_API_KEY=
